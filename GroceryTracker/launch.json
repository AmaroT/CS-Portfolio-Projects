{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug CornerGrocer",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/CornerGrocer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build CornerGrocer",
            "miDebuggerPath": "/usr/bin/gdb",
            "logging": {
                "engineLogging": false
            },
            "launchCompleteCommand": "exec-run",
            "targetArchitecture": "x86_64"
        }
    ]
}
