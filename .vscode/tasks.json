{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build HelloWorld",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "${workspaceFolder}/CS300/HelloWorld/main.cpp",
                "-o",
                "${workspaceFolder}/CS300/HelloWorld/HelloWorld"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Task for building HelloWorld"
        },
        {
            "label": "build VectorSorting",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++11",
                "-g",
				"-arch", "arm64",
                "${workspaceFolder}/CS300/VectorSorting/VectorSorting.cpp",
                "${workspaceFolder}/CS300/VectorSorting/CSVparser.cpp",
                "-o",
                "${workspaceFolder}/CS300/VectorSorting/VectorSorting"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Task for building VectorSorting"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}